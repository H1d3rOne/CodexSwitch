{
  "manifest_version": 3,
  "name": "CodexSwitch",
  "version": "1.0.0",
  "description": "OpenAI API Provider Manager - 管理多个 OpenAI 兼容 API 供应商",
  "permissions": ["storage", "sidePanel", "nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
